{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AppointmentMessage",
  "type": "object",
  "required": [
    "messageId",
    "payload"
  ],
  "properties": {
    "messageId": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "receivedAt": {
      "type": "string"
    },
    "payload": {
      "type": "object",
      "properties": {
        "appointment_id": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "patient": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "dob": {
              "type": "string",
              "format": "date"
            }
          }
        },
        "doctor": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date"
        },
        "time": {
          "type": "string"
        },
        "duration_mins": {
          "type": "integer"
        }
      }
    }
  }
}